# ── Auto-Sync Configuration ───────────────────────────────────────────────────
# Set AUTO_SYNC_ENABLED=true to enable scheduled background sync
AUTO_SYNC_ENABLED=false
# Cron expression — default: every day at 2:00 AM
AUTO_SYNC_CRON=0 2 * * *
# Which data to sync automatically (comma-separated)
# Valid values: chart-of-accounts, ledgers, opening-balances, godowns,
#               cost-centres, stock, vouchers, invoices, taxes
AUTO_SYNC_OPTIONS=ledgers,stock,vouchers
# How many days back to fetch vouchers for auto-sync
AUTO_SYNC_FROM_DAYS=30